<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>You've Been Invited</title></head>
<body style="font-family: system-ui, sans-serif; background: #f8fafc; margin: 0; padding: 32px;">
<div style="max-width: 560px; margin: 0 auto; background: white; border-radius: 8px; padding: 32px; border: 1px solid #e2e8f0;">
  <h1 style="color: #1e1b4b; font-size: 20px; margin-top: 0; margin-bottom: 8px;">You've Been Invited</h1>
  <p style="color: #475569;">Hi {{ recipient_name }},</p>
  <p style="color: #475569;">{{ owner_name }} has invited you to participate in a {{ workflow_label|lower }}.</p>
  <p style="color: #475569;">Resource: <strong>{{ resource_name }}</strong></p>
  {% if assignment_details %}
  <p style="color: #475569;">{{ assignment_details }}</p>
  {% endif %}
  {% if deadline %}
  <div style="background: #f1f5f9; border-left: 3px solid #4f46e5; padding: 10px 14px; border-radius: 4px; margin: 16px 0;">
    <p style="color: #475569; margin: 0; font-size: 14px;"><strong>Deadline:</strong> {{ deadline }}</p>
  </div>
  {% endif %}
  <p style="color: #475569;">Sign in with this email address to accept the invite.</p>
  {% if app_url %}
  <p style="margin: 24px 0;">
    <a href="{{ app_url }}" style="display: inline-block; background: #4f46e5; color: white; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: 600;">Open CompetencyHub</a>
  </p>
  {% endif %}
  <p style="color: #64748b; font-size: 13px; margin-top: 24px; border-top: 1px solid #e2e8f0; padding-top: 16px;">If you were not expecting this invitation, you can safely ignore this email.</p>
</div>
</body>
</html>
