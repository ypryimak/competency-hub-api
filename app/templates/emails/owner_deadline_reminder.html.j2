<html>
  <body style="font-family: Arial, sans-serif; color: #1f2937;">
    <p>Hello {{ recipient_name }},</p>
    <p>Your {{ resource_kind }} <strong>{{ resource_name }}</strong> reaches its deadline in {{ days_before_deadline }} day(s).</p>
    {% if deadline %}
    <p>Deadline: {{ deadline }}</p>
    {% endif %}
    {% if app_url %}
    <p><a href="{{ app_url }}">Open CompetencyHub</a></p>
    {% endif %}
  </body>
</html>
